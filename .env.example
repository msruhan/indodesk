# ============================================================
# IndoTeknizi — Environment Variables
# Copy this file to .env and fill in the values.
# ============================================================

# PostgreSQL (Docker default from docker-compose.yml)
DATABASE_URL="postgresql://indoteknizi:indoteknizi_dev@localhost:5433/indoteknizi?schema=public"

# Auth.js v5
AUTH_SECRET="generate-with-openssl-rand-base64-32"
# Harus sama dengan port server aktif (mis. 3000). Salah port → redirect middleware ke host yang tidak jalan.
AUTH_URL="http://localhost:3000"
# Wajib di production di belakang reverse proxy (Caddy/Nginx)
# AUTH_TRUST_HOST=true

# Google OAuth — untuk login & ulasan teknisi (guest via Google)
# Buat di https://console.cloud.google.com/ → Credentials → OAuth 2.0
# Authorized JavaScript origins:
#   - http://localhost:3000
#   - https://bantoo.in
# Authorized redirect URIs:
#   - http://localhost:3000/api/auth/callback/google
#   - https://bantoo.in/api/auth/callback/google
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Security / Hardening
# CORS allowlist (comma-separated origins). Defaults to NEXT_PUBLIC_APP_URL when empty.
# CORS_ALLOWED_ORIGINS="http://localhost:3000,https://yourdomain.com"
# SESSION_IDLE_SECONDS=7200  # logout setelah 2 jam tanpa aktivitas (default)
# SESSION_UPDATE_AGE_SECONDS=0  # perpanjang cookie tiap request server (default 0)

# Data encryption KEK (32 bytes, base64). Generate: `openssl rand -base64 32`
# DATA_ENCRYPTION_KEY=""

# Upstash Redis (rate limit, replay guards, lockout, etc.) — wajib production
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# Payment gateway webhook (wajib production jika webhook aktif)
# Header: X-Webhook-Secret atau X-Payment-Webhook-Secret
# PAYMENT_WEBHOOK_SECRET=""  # wajib di production; header X-Webhook-Secret atau HMAC sha256 di X-Webhook-Signature

# Tripay Closed Payment (https://tripay.co.id)
# TRIPAY_API_KEY=""
# TRIPAY_PRIVATE_KEY=""
# TRIPAY_MERCHANT_CODE=""
# TRIPAY_MODE=sandbox
# TRIPAY_CALLBACK_URL="https://bantoo.in/api/payments/tripay/callback"

# SMTP — dikonfigurasi di Admin Dashboard → Akun Saya → Pengaturan SMTP (bukan .env).

# IMEI order worker (otomatis saat npm start / npm dev)
# IMEI_ORDER_POLL_INTERVAL_MS=90000
# IMEI_ORDER_SCHEDULER_ENABLED=true

# BinderByte — pelacakan resi marketplace (https://binderbyte.com)
# BINDERBYTE_API_KEY="your-api-key"

# Order tracking worker (otomatis saat npm start / npm dev)
# ORDER_TRACKING_POLL_INTERVAL_MS=900000
# ORDER_TRACKING_MAX_SYNC_PER_TICK=15
# ORDER_TRACKING_SCHEDULER_ENABLED=true

# Opsional: cron eksternal / Vercel Cron (backup jika tanpa long-running server)
# CRON_SECRET="generate-with-openssl-rand-base64-32"
# Panggil: GET /api/cron/order-tracking dengan Authorization: Bearer <CRON_SECRET>

# Cloudflare R2 — upload gambar (avatar, produk, portfolio, dll.)
# R2 → Create bucket → Manage R2 API Tokens → Create Account API token
# Account ID: dashboard Cloudflare (sidebar) atau R2 overview
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="indoteknizi"
R2_ENDPOINT="https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com"
# Public URL: bucket → Settings → Public access (r2.dev) atau custom domain
R2_PUBLIC_BASE_URL="https://pub-xxxxxxxx.r2.dev"

# R2 private bucket (opsional; untuk file sensitif). Jika kosong, mode dev bisa fallback.
# R2_PRIVATE_BUCKET_NAME=""
# R2_PRIVATE_ENDPOINT=""

# Telegram Bot — notifikasi untuk teknisi
# Buat bot di @BotFather → /newbot → copy token
TELEGRAM_BOT_TOKEN=""
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=""
# TELEGRAM_BOT_TOKEN="123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11"
# NEXT_PUBLIC_TELEGRAM_BOT_USERNAME="IndoTekniziiBot"

# Telegram webhook hardening (secret token header)
# TELEGRAM_WEBHOOK_SECRET=""

# Cron secret rotation window (optional)
# CRON_SECRET_OLD=""

# Development / stress testing ONLY — must be false or unset in production
# STRESS_TEST_MODE=false

# Wallet policy (IDR)
# WALLET_DAILY_WITHDRAW_LIMIT=10000000
# WALLET_DAILY_TRANSFER_LIMIT=50000000
# WALLET_DUAL_CONTROL_THRESHOLD=5000000
# WALLET_RECONCILIATION_SCHEDULER_ENABLED=true
# WALLET_RECONCILIATION_INTERVAL_MS=86400000
