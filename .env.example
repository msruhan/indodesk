# ============================================================
# IndoTeknizi — Environment Variables
# Copy this file to .env and fill in the values.
# ============================================================

# PostgreSQL (Docker default from docker-compose.yml)
DATABASE_URL="postgresql://indoteknizi:indoteknizi_dev@localhost:5433/indoteknizi?schema=public"

# Auth.js v5
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Google OAuth — untuk login & ulasan teknisi (guest via Google)
# Buat di https://console.cloud.google.com/ → Credentials → OAuth 2.0
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# IMEI order worker (otomatis saat npm start / npm dev)
# IMEI_ORDER_POLL_INTERVAL_MS=90000
# IMEI_ORDER_SCHEDULER_ENABLED=true

# BinderByte — pelacakan resi marketplace (https://binderbyte.com)
# BINDERBYTE_API_KEY="your-api-key"

# Order tracking worker (otomatis saat npm start / npm dev)
# ORDER_TRACKING_POLL_INTERVAL_MS=900000
# ORDER_TRACKING_MAX_SYNC_PER_TICK=15
# ORDER_TRACKING_SCHEDULER_ENABLED=true

# Opsional: cron eksternal / Vercel Cron (backup jika tanpa long-running server)
# CRON_SECRET="generate-with-openssl-rand-base64-32"
# Panggil: GET /api/cron/order-tracking dengan Authorization: Bearer <CRON_SECRET>

# Cloudflare R2 — upload gambar (avatar, produk, portfolio, dll.)
# R2 → Create bucket → Manage R2 API Tokens → Create Account API token
# Account ID: dashboard Cloudflare (sidebar) atau R2 overview
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="indoteknizi"
R2_ENDPOINT="https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com"
# Public URL: bucket → Settings → Public access (r2.dev) atau custom domain
R2_PUBLIC_BASE_URL="https://pub-xxxxxxxx.r2.dev"

# Telegram Bot — notifikasi untuk teknisi
# Buat bot di @BotFather → /newbot → copy token
TELEGRAM_BOT_TOKEN=""
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=""
# TELEGRAM_BOT_TOKEN="123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11"
# NEXT_PUBLIC_TELEGRAM_BOT_USERNAME="IndoTekniziiBot"
