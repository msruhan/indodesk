# ============================================================
# IndoTeknizi — Environment Variables
# Copy this file to .env and fill in the values.
# ============================================================

# PostgreSQL (Docker default from docker-compose.yml)
DATABASE_URL="postgresql://indoteknizi:indoteknizi_dev@localhost:5433/indoteknizi?schema=public"

# Auth.js v5
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Optional: OAuth providers (leave empty to disable)
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# IMEI order worker (otomatis saat npm start / npm dev)
# IMEI_ORDER_POLL_INTERVAL_MS=90000
# IMEI_ORDER_SCHEDULER_ENABLED=true

# Opsional: cron eksternal / Vercel Cron (backup jika tanpa long-running server)
# CRON_SECRET="generate-with-openssl-rand-base64-32"
