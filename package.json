{
  "name": "indoteknizi",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:clean": "rm -rf .next && next build",
    "build:fast": "SKIP_TYPECHECK=1 next build",
    "typecheck": "tsc --noEmit",
    "typecheck:scripts": "tsc --noEmit -p tsconfig.scripts.json",
    "typecheck:all": "npm run typecheck && npm run typecheck:scripts",
    "start": "next start",
    "lint": "next lint",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "npx prisma migrate dev",
    "db:push": "npx prisma db push",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:studio": "npx prisma studio",
    "db:reset": "npx prisma migrate reset --force",
    "db:generate": "npx prisma generate",
    "db:setup:production": "prisma migrate deploy",
    "db:bootstrap-admin": "tsx scripts/bootstrap-admin.ts",
    "test:r2": "npx tsx scripts/test-r2-upload.ts",
    "stress:seed": "tsx stress-test/seed/stress-seed.ts",
    "stress:clean": "tsx stress-test/seed/clean.ts",
    "stress:smoke": "k6 run stress-test/scenarios/01-public-discovery.js --vus 1 --duration 30s",
    "stress:1": "k6 run stress-test/scenarios/01-public-discovery.js",
    "stress:2": "k6 run stress-test/scenarios/02-marketplace-checkout.js",
    "stress:3": "k6 run stress-test/scenarios/03-service-request.js",
    "stress:4": "k6 run stress-test/scenarios/04-realtime-polling.js",
    "stress:soak": "k6 run stress-test/scenarios/05-soak-test.js",
    "stress:all": "npm run stress:1 && npm run stress:2 && npm run stress:3 && npm run stress:4",
    "lint:ft": "tsx scripts/lint-functional-tests.ts",
    "test:ft": "tsx scripts/functional-smoke-test.ts",
    "test:ft:full": "tsx scripts/functional-full-test.ts",
    "test:ft:batches": "tsx scripts/run-all-ft-batches.ts",
    "secrets:encrypt": "tsx scripts/encrypt-existing-secrets.ts",
    "secrets:rotate": "tsx scripts/rotate-secrets.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@aws-sdk/client-s3": "^3.1053.0",
    "@aws-sdk/s3-request-presigner": "^3.1053.0",
    "@phosphor-icons/react": "^2.1.10",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-tabs": "^1.1.13",
    "@types/leaflet": "^1.9.21",
    "@types/pdfkit": "^0.17.6",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "apexcharts": "^5.11.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "file-type": "^22.0.1",
    "framer-motion": "^11.11.17",
    "leaflet": "^1.9.4",
    "next": "^16.1.0",
    "next-auth": "^5.0.0-beta.31",
    "nodemailer": "^8.0.8",
    "otplib": "^13.4.0",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "prisma": "^7.8.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-apexcharts": "^2.1.0",
    "react-dom": "^18.3.1",
    "react-leaflet": "^5.0.0",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.5.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.17.6",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.20",
    "dotenv": "^17.4.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.22.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.7"
  },
  "optionalDependencies": {
    "@next/swc-darwin-arm64": "^16.1.0"
  }
}
