# Salin file ini ke .env.local (gitignored) jika menjalankan `npm start` di mesin lokal.
# Tanpa ini, Next.js memuat .env.production → AUTH_URL=https://bantoo.in
# sehingga Google OAuth memakai redirect URI production, bukan localhost.

AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Opsional: matikan trust host di lokal jika tidak di belakang proxy
# AUTH_TRUST_HOST=false
