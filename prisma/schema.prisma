  PAYMENT_GATEWAY
  LEGACY_DEBIT
}

enum KonsultasiPaymentStatus {
  UNPAID
  HELD
  PAID
  SECURED
  CAPTURED
  RELEASED
}

model KonsultasiSession {
  id        String           @id @default(cuid())
  userId    String
  teknisiId String
  service   String // e.g. "Konsultasi Unlock"
  price     Decimal          @db.Decimal(12, 0)
  platformFee Decimal        @default(0) @db.Decimal(12, 0)
