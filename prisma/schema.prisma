// ============================================================
// IndoTeknizi — Prisma Schema
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// AUTH.JS MODELS (required by @auth/prisma-adapter)
// ============================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================
// USER & ROLES
// ============================================================

enum UserRole {
  ADMIN
  TEKNISI
  USER
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String? // hashed with bcrypt (null for OAuth-only users)
  role          UserRole  @default(USER)
  phone         String?
  address       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts         Account[]
  sessions         Session[]
  teknisiProfile   TeknisiProfile?
  products         Product[]
  ordersAsBuyer    Order[]             @relation("BuyerOrders")
  ordersAsSeller   Order[]             @relation("SellerOrders")
  wallet           Wallet?
  rekberAsBuyer    RekberTransaction[] @relation("RekberBuyer")
  rekberAsSeller   RekberTransaction[] @relation("RekberSeller")
  topupOrders      TopupOrder[]
  konsultasiAsUser KonsultasiSession[] @relation("KonsultasiUser")
  konsultasiAsTech KonsultasiSession[] @relation("KonsultasiTeknisi")
  lowonganPosted   Lowongan[]
  applications     LowonganApplication[]
  remoteAsUser     RemoteSession[]     @relation("RemoteUser")
  remoteAsTech     RemoteSession[]     @relation("RemoteTeknisi")
}

// ============================================================
// TEKNISI PROFILE (extends User where role = TEKNISI)
// ============================================================

model TeknisiProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  specialty      String[] // e.g. ["Unlock", "Flashing", "Root"]
  experience     String?  // e.g. "8 tahun"
  location       String?
  description    String?  @db.Text
  rating         Decimal  @default(0) @db.Decimal(3, 2)
  reviewCount    Int      @default(0)
  totalKonsultasi Int     @default(0)
  totalView      Int      @default(0)
  responseTime   String?  // e.g. "< 5 menit"
  completionRate Int      @default(0) // percentage
  isOnline       Boolean  @default(false)
  isVerified     Boolean  @default(false)
  price          Decimal  @default(0) @db.Decimal(12, 0) // starting price IDR
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================================
// MARKETPLACE — PRODUCTS & ORDERS
// ============================================================

enum ProductCategory {
  HANDPHONE
  LAPTOP
  AKSESORIS
  SOFTWARE
}

model Product {
  id          String          @id @default(cuid())
  sellerId    String
  name        String
  category    ProductCategory
  price       Decimal         @db.Decimal(12, 0)
  description String?         @db.Text
  image       String?
  rating      Decimal         @default(0) @db.Decimal(3, 2)
  reviewCount Int             @default(0)
  views       Int             @default(0)
  stock       Int             @default(0)
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  seller     User        @relation(fields: [sellerId], references: [id])
  orderItems OrderItem[]
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  COMPLETED
  CANCELLED
  REFUNDED
}

model Order {
  id          String      @id @default(cuid())
  orderCode   String      @unique // e.g. "ORD-2026-XXXXXX"
  buyerId     String
  sellerId    String
  subtotal    Decimal     @db.Decimal(12, 0)
  fee         Decimal     @default(0) @db.Decimal(12, 0)
  discount    Decimal     @default(0) @db.Decimal(12, 0)
  total       Decimal     @db.Decimal(12, 0)
  status      OrderStatus @default(PENDING)
  note        String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  buyer  User        @relation("BuyerOrders", fields: [buyerId], references: [id])
  seller User        @relation("SellerOrders", fields: [sellerId], references: [id])
  items  OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int     @default(1)
  price     Decimal @db.Decimal(12, 0)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

// ============================================================
// WALLET & LEDGER
// ============================================================

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Decimal  @default(0) @db.Decimal(14, 0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  ledger WalletLedger[]
}

enum LedgerType {
  TOPUP
  WITHDRAWAL
  PAYMENT
  REFUND
  ESCROW_HOLD
  ESCROW_RELEASE
  EARNING
  CASHBACK
}

model WalletLedger {
  id          String     @id @default(cuid())
  walletId    String
  type        LedgerType
  amount      Decimal    @db.Decimal(14, 0) // positive = credit, negative = debit
  balance     Decimal    @db.Decimal(14, 0) // balance after this entry
  description String?
  referenceId String?    // order/rekber/topup ID
  createdAt   DateTime   @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId, createdAt])
}

// ============================================================
// REKBER (ESCROW)
// ============================================================

enum RekberStatus {
  PENDING
  HELD
  RELEASED
  DISPUTED
  REFUNDED
}

model RekberTransaction {
  id          String       @id @default(cuid())
  orderCode   String       @unique
  buyerId     String
  sellerId    String
  amount      Decimal      @db.Decimal(12, 0)
  fee         Decimal      @default(0) @db.Decimal(12, 0)
  status      RekberStatus @default(PENDING)
  description String?      @db.Text
  note        String?      @db.Text
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  heldAt      DateTime?
  releasedAt  DateTime?
  disputedAt  DateTime?
  refundedAt  DateTime?

  buyer  User @relation("RekberBuyer", fields: [buyerId], references: [id])
  seller User @relation("RekberSeller", fields: [sellerId], references: [id])
}

// ============================================================
// TOP UP
// ============================================================

enum TopupStatus {
  PENDING_PAYMENT
  PAID
  PROCESSING
  FULFILLING
  COMPLETED
  FAILED
}

model TopupOrder {
  id              String      @id @default(cuid())
  orderCode       String      @unique // e.g. "TT-XXXXXX-2026"
  userId          String?     // nullable for guest checkout
  productSlug     String
  denominationSku String
  accountId       String      // target game/phone ID
  serverId        String?
  email           String?
  whatsapp        String?
  subtotal        Decimal     @db.Decimal(12, 0)
  discount        Decimal     @default(0) @db.Decimal(12, 0)
  fee             Decimal     @default(0) @db.Decimal(12, 0)
  total           Decimal     @db.Decimal(12, 0)
  paymentMethod   String?
  status          TopupStatus @default(PENDING_PAYMENT)
  providerOrderId String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  paidAt          DateTime?
  fulfilledAt     DateTime?

  user User? @relation(fields: [userId], references: [id])
}

// ============================================================
// KONSULTASI
// ============================================================

enum KonsultasiStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
}

model KonsultasiSession {
  id         String           @id @default(cuid())
  userId     String
  teknisiId  String
  service    String           // e.g. "Konsultasi Unlock"
  price      Decimal          @db.Decimal(12, 0)
  status     KonsultasiStatus @default(PENDING)
  rating     Int?             // 1-5
  review     String?          @db.Text
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  startedAt  DateTime?
  endedAt    DateTime?

  user    User @relation("KonsultasiUser", fields: [userId], references: [id])
  teknisi User @relation("KonsultasiTeknisi", fields: [teknisiId], references: [id])
}

// ============================================================
// REMOTE SESSION
// ============================================================

enum RemoteStatus {
  WAITING
  ACCEPTED
  REJECTED
  IN_PROGRESS
  COMPLETED
}

model RemoteSession {
  id          String       @id @default(cuid())
  userId      String
  teknisiId   String
  remoteId    String       // IndoDesk ID
  description String?      @db.Text
  platform    String?      // e.g. "Windows 11"
  status      RemoteStatus @default(WAITING)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  acceptedAt  DateTime?
  completedAt DateTime?

  user    User @relation("RemoteUser", fields: [userId], references: [id])
  teknisi User @relation("RemoteTeknisi", fields: [teknisiId], references: [id])
}

// ============================================================
// LOWONGAN (JOB LISTINGS)
// ============================================================

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
}

model Lowongan {
  id           String   @id @default(cuid())
  posterId     String
  title        String
  company      String
  location     String
  salary       String?
  type         JobType  @default(FULL_TIME)
  description  String   @db.Text
  requirements String[] // array of requirement strings
  skills       String[]
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  poster       User                  @relation(fields: [posterId], references: [id])
  applications LowonganApplication[]
}

model LowonganApplication {
  id          String   @id @default(cuid())
  lowonganId  String
  applicantId String
  name        String
  email       String
  phone       String
  coverLetter String?  @db.Text
  status      String   @default("pending") // pending | reviewed | accepted | rejected
  createdAt   DateTime @default(now())

  lowongan  Lowongan @relation(fields: [lowonganId], references: [id], onDelete: Cascade)
  applicant User     @relation(fields: [applicantId], references: [id])
}
