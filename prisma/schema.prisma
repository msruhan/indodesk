// ============================================================
// IndoTeknizi — Prisma Schema
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// AUTH.JS MODELS (required by @auth/prisma-adapter)
// ============================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model TelegramVerification {
  id        String   @id @default(cuid())
  userId    String
  code      String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([code, expiresAt])
}

// ============================================================
// USER & ROLES
// ============================================================

enum UserRole {
  ADMIN
  TEKNISI
  USER
}

enum TeknisiVerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String? // hashed with bcrypt (null for OAuth-only users)
  role          UserRole  @default(USER)
  isActive           Boolean   @default(true)
  phone              String?
  address            String?
  twoFactorEnabled   Boolean   @default(false)
  twoFactorSecret    String?   @db.Text
  passwordChangedAt  DateTime?
  telegramUserId     String?   @unique // Telegram user ID for notifications
  telegramUsername   String?   // Telegram username (optional)
  telegramChatId     String?   // Telegram chat ID for sending messages
  telegramLinkedAt   DateTime? // When Telegram was linked
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Relations
  accounts         Account[]
  sessions         Session[]
  teknisiProfile   TeknisiProfile?
  products         Product[]
  ordersAsBuyer    Order[]               @relation("BuyerOrders")
  ordersAsSeller   Order[]               @relation("SellerOrders")
  wallet           Wallet?
  rekberAsBuyer    RekberTransaction[]   @relation("RekberBuyer")
  rekberAsSeller   RekberTransaction[]   @relation("RekberSeller")
  topupOrders      TopupOrder[]
  konsultasiAsUser KonsultasiSession[]   @relation("KonsultasiUser")
  konsultasiAsTech KonsultasiSession[]   @relation("KonsultasiTeknisi")
  lowonganPosted   Lowongan[]
  applications     LowonganApplication[]
  remoteAsUser     RemoteSession[]       @relation("RemoteUser")
  remoteAsTech     RemoteSession[]       @relation("RemoteTeknisi")
  imeiOrders       ImeiOrder[]
  serverOrders     ServerOrder[]
  chatAsUser       ChatConversation[]    @relation("ChatAsUser")
  chatAsTeknisi    ChatConversation[]    @relation("ChatAsTeknisi")
  chatMessagesSent ChatMessage[]
  teknisiStore              TeknisiStore?
  activityLogs              ActivityLog[]
  teknisiReviewsReceived    TeknisiReview[] @relation("TeknisiReviewsReceived")
  teknisiReviewsAuthored    TeknisiReview[] @relation("TeknisiReviewsAuthored")
  teknisiPortfolioCases     TeknisiPortfolioCase[] @relation("TeknisiPortfolioCases")
  inspectionOrdersAsUser  InspectionOrder[]      @relation("InspectionUser")
  inspectionOrdersAsTech  InspectionOrder[]      @relation("InspectionTeknisi")
  telegramVerifications   TelegramVerification[]
}

// ============================================================
// TEKNISI PROFILE (extends User where role = TEKNISI)
// ============================================================

model TeknisiProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  specialty       String[] // e.g. ["Unlock", "Flashing", "Root"]
  experience      String? // e.g. "8 tahun"
  coverImage      String? // banner profil publik
  location        String?
  description     String?  @db.Text
  tagline         String?  @db.Text
  issuesHandled   String?  @db.Text
  brandFocus      String?  @db.Text
  workApproach    String?  @db.Text
  serviceScope    String[]             @default([])
  languages       String[]             @default([])
  secondarySkills String[]             @default([])
  operatingHours  Json                 @default("{}")
  consultationServices Json            @default("[]")
  rating          Decimal  @default(0) @db.Decimal(3, 2)
  reviewCount     Int      @default(0)
  totalKonsultasi Int      @default(0)
  totalView       Int      @default(0)
  responseTime    String? // e.g. "< 5 menit"
  completionRate  Int      @default(0) // percentage
  isOnline            Boolean                   @default(false)
  isVerified          Boolean                   @default(false)
  providesInspection  Boolean                   @default(false) // Teknisi menyediakan layanan inspeksi HP/Laptop
  inspectionPriceOnline  Decimal? @db.Decimal(12, 0) // tarif inspeksi online (video call) IDR
  inspectionPriceOffline Decimal? @db.Decimal(12, 0) // tarif inspeksi offline (on-site) IDR
  verificationStatus  TeknisiVerificationStatus @default(PENDING)
  rejectionReason     String?                   @db.Text
  applicationData     Json                      @default("{}")
  price               Decimal                   @default(0) @db.Decimal(12, 0) // starting price IDR
  telegramChatId      String?                   @unique // Telegram chat ID untuk notifikasi
  telegramUsername    String? // Telegram username (tanpa @)
  telegramLinkedAt    DateTime? // Waktu sinkronisasi Telegram
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================================
// TEKNISI REVIEWS (ulasan profil teknisi dari user terdaftar / Google)
// ============================================================

model TeknisiReview {
  id        String   @id @default(cuid())
  teknisiId String
  authorId  String
  rating    Int // 1–5
  tag       String?
  comment   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teknisi User @relation("TeknisiReviewsReceived", fields: [teknisiId], references: [id], onDelete: Cascade)
  author  User @relation("TeknisiReviewsAuthored", fields: [authorId], references: [id], onDelete: Cascade)

  @@unique([teknisiId, authorId])
  @@index([teknisiId, createdAt(sort: Desc)])
}

// ============================================================
// TEKNISI PORTFOLIO (case highlights di profil publik)
// ============================================================

model TeknisiPortfolioCase {
  id        String   @id @default(cuid())
  teknisiId String
  title     String
  meta      String
  result    String
  imageUrl  String? // foto aktivitas servis
  icon      String // smartphone | wrench | laptop
  tone      String // tailwind gradient e.g. from-primary-500 to-emerald-600
  glow      String // rgba glow for hover effects
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teknisi User @relation("TeknisiPortfolioCases", fields: [teknisiId], references: [id], onDelete: Cascade)

  @@index([teknisiId, sortOrder])
}

// ============================================================
// TEKNISI STORE (Toko handphone — 1 per teknisi)
// ============================================================

model TeknisiStore {
  id            String               @id @default(cuid())
  userId        String               @unique
  name          String
  city          String?
  address       String?
  phone         String?
  email         String?
  instagram     String?
  threads       String?
  tiktok        String?
  jamWeekdays   String?
  jamWeekend    String?
  operatingHours Json                 @default("{}")
  coverImage    String?
  gallery       String[]             @default([])
  layanan       String[]             @default([])
  journeyIntro  String?
  journey       Json                 @default("[]")
  badge         String?
  listingStatus ProductListingStatus @default(APPROVED)
  isPublished   Boolean              @default(false)
  profileViews  Int                  @default(0)
  totalSold     Int                  @default(0)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isPublished, listingStatus])
}

// ============================================================
// MARKETPLACE — PRODUCTS & ORDERS
// ============================================================

enum ProductCategory {
  HANDPHONE
  LAPTOP
  AKSESORIS
  SOFTWARE
  LAINNYA
}

enum ProductListingStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

enum ProductWarranty {
  NONE
  OFFICIAL
  STORE
}

model Product {
  id             String               @id @default(cuid())
  sellerId       String
  name           String
  category       ProductCategory
  price          Decimal              @db.Decimal(12, 0)
  description    String?              @db.Text
  color          String               @default("")
  ram            String               @default("")
  processor      String               @default("")
  storage        String               @default("")
  warranty       ProductWarranty      @default(NONE)
  completeness   Json                 @default("[]")
  image          String?
  images         Json                 @default("[]")
  rating         Decimal              @default(0) @db.Decimal(3, 2)
  reviewCount    Int                  @default(0)
  views          Int                  @default(0)
  soldCount      Int                  @default(0)
  stock          Int                  @default(1)
  listingStatus  ProductListingStatus @default(DRAFT)
  isPublished    Boolean              @default(false)
  isActive       Boolean              @default(true)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  seller     User        @relation(fields: [sellerId], references: [id])
  orderItems OrderItem[]
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  COMPLETED
  CANCELLED
  REFUNDED
}

/// Kode kurir — dipetakan ke BinderByte (`jne`, `jnt`, …)
enum ShippingCourier {
  JNE
  POS
  JNT
  SICEPAT
  TIKI
  ANTERAJA
  WAHANA
  NINJA
  LION
}

model Order {
  id        String      @id @default(cuid())
  orderCode String      @unique // e.g. "ORD-2026-XXXXXX"
  buyerId   String
  sellerId  String
  subtotal  Decimal     @db.Decimal(12, 0)
  fee       Decimal     @default(0) @db.Decimal(12, 0)
  discount  Decimal     @default(0) @db.Decimal(12, 0)
  total     Decimal     @db.Decimal(12, 0)
  status    OrderStatus @default(PENDING)
  note      String?

  shippingCourier       ShippingCourier?
  trackingNumber        String?
  trackingSummaryStatus String?
  trackingSummaryDesc   String?          @db.Text
  trackingLastEventAt   DateTime?
  trackingLastSyncedAt  DateTime?
  trackingNextSyncAt    DateTime?
  trackingActive        Boolean          @default(false)
  trackingSyncFailures  Int              @default(0)
  shippedAt             DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  buyer          User                 @relation("BuyerOrders", fields: [buyerId], references: [id])
  seller         User                 @relation("SellerOrders", fields: [sellerId], references: [id])
  items          OrderItem[]
  trackingEvents OrderTrackingEvent[]

  @@index([trackingActive, trackingNextSyncAt])
  @@index([status, trackingActive])
}

model OrderTrackingEvent {
  id          String   @id @default(cuid())
  orderId     String
  occurredAt  DateTime
  description String   @db.Text
  location    String?
  createdAt   DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, occurredAt(sort: Desc)])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int     @default(1)
  price     Decimal @db.Decimal(12, 0)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

// ============================================================
// WALLET & LEDGER
// ============================================================

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Decimal  @default(0) @db.Decimal(14, 0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  ledger WalletLedger[]
}

enum LedgerType {
  TOPUP
  WITHDRAWAL
  PAYMENT
  REFUND
  ESCROW_HOLD
  ESCROW_RELEASE
  EARNING
  CASHBACK
}

model WalletLedger {
  id          String     @id @default(cuid())
  walletId    String
  type        LedgerType
  amount      Decimal    @db.Decimal(14, 0) // positive = credit, negative = debit
  balance     Decimal    @db.Decimal(14, 0) // balance after this entry
  description String?
  referenceId String? // order/rekber/topup ID
  createdAt   DateTime   @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId, createdAt])
}

// ============================================================
// REKBER (ESCROW)
// ============================================================

enum RekberStatus {
  PENDING
  HELD
  RELEASED
  DISPUTED
  REFUNDED
}

model RekberTransaction {
  id          String       @id @default(cuid())
  orderCode   String       @unique
  buyerId     String
  sellerId    String
  amount      Decimal      @db.Decimal(12, 0)
  fee         Decimal      @default(0) @db.Decimal(12, 0)
  status      RekberStatus @default(PENDING)
  description String?      @db.Text
  note        String?      @db.Text
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  heldAt      DateTime?
  releasedAt  DateTime?
  disputedAt  DateTime?
  refundedAt  DateTime?

  inspectionOrderId String? @unique
  inspectionOrder   InspectionOrder? @relation(fields: [inspectionOrderId], references: [id], onDelete: SetNull)

  buyer  User @relation("RekberBuyer", fields: [buyerId], references: [id])
  seller User @relation("RekberSeller", fields: [sellerId], references: [id])
}

// ============================================================
// TOP UP
// ============================================================

model TopupCatalogProduct {
  id           String   @id @default(cuid())
  slug         String   @unique
  category     String
  name         String
  publisher    String
  logo         String
  cover        String
  accent       String   @default("")
  description  String   @db.Text
  rating       Decimal  @default(4.8) @db.Decimal(2, 1)
  ratingCount  Int      @default(0)
  ordersToday  Int      @default(0)
  isHot        Boolean  @default(false)
  isActive     Boolean  @default(true)
  idLabel      String   @default("User ID")
  serverLabel  String?
  idHelp       String   @db.Text
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  denominations TopupDenomination[]
}

model TopupDenomination {
  id              String    @id @default(cuid())
  productId       String
  sku             String    @unique
  group           String
  label           String
  note            String?
  basePrice       Decimal   @db.Decimal(12, 0)
  salePrice       Decimal?  @db.Decimal(12, 0)
  badge           String?
  flashSaleSold   Int?
  flashSaleQuota  Int?
  flashSaleEndsAt DateTime?
  isActive        Boolean   @default(true)
  sortOrder       Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  product TopupCatalogProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
}

enum TopupStatus {
  PENDING_PAYMENT
  PAID
  PROCESSING
  FULFILLING
  COMPLETED
  FAILED
}

model TopupOrder {
  id              String      @id @default(cuid())
  orderCode       String      @unique // e.g. "TT-XXXXXX-2026"
  userId          String? // nullable for guest checkout
  productSlug     String
  denominationSku String
  accountId       String // target game/phone ID
  serverId        String?
  email           String?
  whatsapp        String?
  subtotal        Decimal     @db.Decimal(12, 0)
  discount        Decimal     @default(0) @db.Decimal(12, 0)
  fee             Decimal     @default(0) @db.Decimal(12, 0)
  total           Decimal     @db.Decimal(12, 0)
  paymentMethod   String?
  status          TopupStatus @default(PENDING_PAYMENT)
  providerOrderId String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  paidAt          DateTime?
  fulfilledAt     DateTime?

  user User? @relation(fields: [userId], references: [id])
}

// ============================================================
// KONSULTASI
// ============================================================

enum KonsultasiStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
}

model KonsultasiSession {
  id        String           @id @default(cuid())
  userId    String
  teknisiId String
  service   String // e.g. "Konsultasi Unlock"
  price     Decimal          @db.Decimal(12, 0)
  status    KonsultasiStatus @default(PENDING)
  rating    Int? // 1-5
  review    String?          @db.Text
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  startedAt DateTime?
  endedAt   DateTime?

  user    User @relation("KonsultasiUser", fields: [userId], references: [id])
  teknisi User @relation("KonsultasiTeknisi", fields: [teknisiId], references: [id])
}

// ============================================================
// CHAT (User ↔ Teknisi)
// ============================================================

model ChatConversation {
  id            String    @id @default(cuid())
  userId        String
  teknisiId     String
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user     User          @relation("ChatAsUser", fields: [userId], references: [id], onDelete: Cascade)
  teknisi  User          @relation("ChatAsTeknisi", fields: [teknisiId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@unique([userId, teknisiId])
  @@index([userId, lastMessageAt(sort: Desc)])
  @@index([teknisiId, lastMessageAt(sort: Desc)])
}

model ChatMessage {
  id             String    @id @default(cuid())
  conversationId String
  senderId       String
  body           String    @db.Text
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User             @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

// ============================================================
// REMOTE SESSION
// ============================================================

enum RemoteStatus {
  WAITING
  ACCEPTED
  REJECTED
  IN_PROGRESS
  COMPLETED
}

model RemoteSession {
  id          String       @id @default(cuid())
  userId      String
  teknisiId   String
  remoteId    String // IndoDesk ID
  remoteOtp   String? // One-time password IndoDesk (cleared after session ends)
  description String?      @db.Text
  platform    String? // e.g. "Windows 11"
  status      RemoteStatus @default(WAITING)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  acceptedAt  DateTime?
  completedAt DateTime?

  user    User @relation("RemoteUser", fields: [userId], references: [id])
  teknisi User @relation("RemoteTeknisi", fields: [teknisiId], references: [id])
}

// ============================================================
// INSPECTION (pra-beli HP / Laptop)
// ============================================================

enum InspectionMode {
  ONLINE
  OFFLINE
}

enum InspectionDeviceCategory {
  HANDPHONE
  LAPTOP
}

enum InspectionProductSource {
  INDOTEKNIZII
  TOKOPEDIA
  SHOPEE
  OLX
  FACEBOOK_MARKETPLACE
  PRIVATE
  OTHER
}

enum InspectionOrderStatus {
  PAID
  ACCEPTED
  REJECTED
  IN_PROGRESS
  REPORT_SUBMITTED
  COMPLETED
  CANCELLED
  DISPUTED
}

enum InspectionOverallCondition {
  EXCELLENT
  GOOD
  FAIR
  POOR
}

enum InspectionRecommendation {
  RECOMMENDED
  NEGOTIATE
  NOT_RECOMMENDED
}

model InspectionOrder {
  id              String                   @id @default(cuid())
  orderCode       String                   @unique
  userId          String
  teknisiId       String
  mode            InspectionMode
  category        InspectionDeviceCategory
  status          InspectionOrderStatus    @default(PAID)
  productId       String?
  productName     String
  productBrand    String                   @default("")
  productModel    String                   @default("")
  productSource   InspectionProductSource  @default(OTHER)
  productSourceUrl String?
  sellerContact   String?
  notes           String?                  @db.Text
  location        String?
  city            String?
  scheduledAt     DateTime?
  price           Decimal                  @db.Decimal(12, 0)
  platformFee     Decimal                  @db.Decimal(12, 0)
  teknisiEarning  Decimal                  @db.Decimal(12, 0)
  paidAt          DateTime                 @default(now())
  acceptedAt      DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  ratingByUser    Int?
  reviewByUser    String?                  @db.Text
  cancelReason    String?                  @db.Text
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  user    User              @relation("InspectionUser", fields: [userId], references: [id])
  teknisi User              @relation("InspectionTeknisi", fields: [teknisiId], references: [id])
  report  InspectionReport?
  rekber  RekberTransaction?

  @@index([userId, createdAt(sort: Desc)])
  @@index([teknisiId, status])
  @@index([status])
}

model InspectionReport {
  id               String                     @id @default(cuid())
  inspectionOrderId String                    @unique
  overallCondition InspectionOverallCondition
  recommendation   InspectionRecommendation
  checklistData    Json
  findings         String                     @db.Text
  suggestions      String?                    @db.Text
  photoUrls        String[]                   @default([])
  certificateNumber String                  @unique
  submittedAt      DateTime                   @default(now())
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt

  order InspectionOrder @relation(fields: [inspectionOrderId], references: [id], onDelete: Cascade)
}

// ============================================================
// LOWONGAN (JOB LISTINGS)
// ============================================================

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
}

model Lowongan {
  id           String   @id @default(cuid())
  posterId     String
  title        String
  company      String
  location     String
  salary       String?
  type         JobType  @default(FULL_TIME)
  description  String   @db.Text
  requirements String[] // array of requirement strings
  skills       String[]
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  poster       User                  @relation(fields: [posterId], references: [id])
  applications LowonganApplication[]
}

model LowonganApplication {
  id          String   @id @default(cuid())
  lowonganId  String
  applicantId String
  name        String
  email       String
  phone       String
  coverLetter String?  @db.Text
  status      String   @default("pending") // pending | reviewed | accepted | rejected
  createdAt   DateTime @default(now())

  lowongan  Lowongan @relation(fields: [lowonganId], references: [id], onDelete: Cascade)
  applicant User     @relation(fields: [applicantId], references: [id])
}

// ============================================================
// IMEI SERVICE — API Manager, Service Groups, Services, Orders
// ============================================================

enum ImeiApiStatus {
  ACTIVE
  INACTIVE
}

enum ImeiServiceStatus {
  ACTIVE
  INACTIVE
}

enum ImeiOrderStatus {
  PENDING
  IN_PROCESS
  SUCCESS
  REJECTED
  CANCELLED
}

/// API Provider/Supplier (e.g. DhruFusion, UnlockBase)
model ImeiApi {
  id        String        @id @default(cuid())
  title     String
  host      String
  username  String
  apiKey    String        @db.Text
  apiType   String        @default("DhruFusion") // DhruFusion | UnlockBase | Custom
  libraryId Int           @default(1)
  status    ImeiApiStatus @default(ACTIVE)
  notes     String?       @db.Text
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  services       ImeiService[]
  serverServices ServerService[]

  @@index([status])
}

/// Service Group (Network/Category) — e.g. "Samsung Unlock", "iPhone iCloud"
model ImeiServiceGroup {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  services ImeiService[]
}

/// Individual IMEI Service (a "method" in DhruFusion terminology)
model ImeiService {
  id           String            @id @default(cuid())
  apiId        String
  groupId      String
  toolId       String? // external tool/service ID from supplier
  title        String
  description  String?           @db.Text
  price        Decimal           @db.Decimal(12, 0) // IDR
  deliveryTime String? // e.g. "1-24 jam"
  status       ImeiServiceStatus @default(ACTIVE)

  // Required fields (from DhruFusion API spec)
  requiresImei     Boolean @default(true)
  requiresNetwork  Boolean @default(false)
  requiresModel    Boolean @default(false)
  requiresProvider Boolean @default(false)
  requiresPin      Boolean @default(false)
  requiresKbh      Boolean @default(false)
  requiresMep      Boolean @default(false)
  requiresPrd      Boolean @default(false)
  requiresSn       Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  api    ImeiApi          @relation(fields: [apiId], references: [id], onDelete: Cascade)
  group  ImeiServiceGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  orders ImeiOrder[]

  @@index([groupId, status])
  @@index([apiId])
}

/// IMEI Order placed by user
model ImeiOrder {
  id        String          @id @default(cuid())
  orderCode String          @unique // e.g. "IMEI-2026-XXXXXX"
  userId    String
  serviceId String
  imei      String
  price     Decimal         @db.Decimal(12, 0)
  status    ImeiOrderStatus @default(PENDING)

  // Optional input fields
  network      String?
  model        String?
  provider     String?
  pin          String?
  kbh          String?
  mep          String?
  prd          String?
  serialNumber String?
  note         String? @db.Text

  // Result fields
  code        String? @db.Text // unlock code / result
  comments    String? @db.Text // admin/system comments
  referenceId String? // external supplier reference ID

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  processedAt DateTime?
  completedAt DateTime?

  user    User        @relation(fields: [userId], references: [id])
  service ImeiService @relation(fields: [serviceId], references: [id])

  @@index([userId, status])
  @@index([status, createdAt])
  @@index([imei])
}

// ============================================================
// SERVER SERVICE — Server-based unlock/flash services
// ============================================================

enum ServerOrderStatus {
  PENDING
  IN_PROCESS
  SUCCESS
  REJECTED
  CANCELLED
}

/// Server Box — grouping for server services (e.g. "Samsung Server", "iPhone Server")
model ServerServiceBox {
  id        String   @id @default(cuid())
  title     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  services ServerService[]
}

/// Individual Server Service
model ServerService {
  id             String            @id @default(cuid())
  apiId          String
  boxId          String
  toolId         String? // external tool ID from supplier
  title          String
  description    String?           @db.Text
  price          Decimal           @db.Decimal(12, 0)
  deliveryTime   String?
  quantity       Int               @default(1)
  requiredFields String?           @db.Text // JSON schema of required input fields
  status         ImeiServiceStatus @default(ACTIVE)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  api    ImeiApi          @relation(fields: [apiId], references: [id], onDelete: Cascade)
  box    ServerServiceBox @relation(fields: [boxId], references: [id], onDelete: Cascade)
  orders ServerOrder[]

  @@index([boxId, status])
  @@index([apiId])
}

/// Server Order placed by user
model ServerOrder {
  id             String            @id @default(cuid())
  orderCode      String            @unique
  userId         String
  serviceId      String
  price          Decimal           @db.Decimal(12, 0)
  status         ServerOrderStatus @default(PENDING)
  requiredFields String?           @db.Text // JSON of user-submitted field values
  email          String?
  notes          String?           @db.Text
  code           String?           @db.Text // result
  comments       String?           @db.Text
  referenceId    String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  processedAt    DateTime?
  completedAt    DateTime?

  user    User          @relation(fields: [userId], references: [id])
  service ServerService @relation(fields: [serviceId], references: [id])

  @@index([userId, status])
  @@index([status, createdAt])
}

// ============================================================
// PLATFORM NOTIFICATIONS (bell popup — shared across roles)
// ============================================================

model PlatformNotification {
  id        String   @id @default(cuid())
  title     String
  body      String   @db.Text
  audiences Json // ["USER","TEKNISI","ADMIN"]
  tone      String   @default("primary")
  icon      String   @default("bell")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, createdAt(sort: Desc)])
}

// ============================================================
// MARKETPLACE BANNERS (admin-managed slides)
// ============================================================

model MarketplaceBanner {
  id         String   @id @default(cuid())
  title      String
  subtitle   String   @default("")
  image      String   @db.Text
  link       String   @db.Text
  buttonText String   @default("Lihat")
  active     Boolean  @default(true)
  sortOrder  Int      @default(0)
  /// marketplace | shop | topup
  placement  String   @default("marketplace")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([placement, active, sortOrder])
}

// ============================================================
// PLATFORM SETTINGS (key-value)
// ============================================================

model PlatformSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

// ============================================================
// HELP / FAQ
// ============================================================

model HelpArticle {
  id        String   @id @default(cuid())
  /// user | teknisi | admin
  audience  String
  question  String   @db.Text
  answer    String   @db.Text
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([audience, isActive, sortOrder])
}

// ============================================================
// INODESK DOWNLOAD LINKS (admin-managed)
// ============================================================
enum IndodeskPlatform {
  WINDOWS
  MACOS
}

model IndodeskDownload {
  id          String           @id @default(cuid())
  platform    IndodeskPlatform @unique
  downloadUrl String           @db.Text
  version     String           @default("1.3.7")
  fileSize    String?          @default("~15 MB")
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}


// ============================================================
// ACTIVITY LOG (audit trail across all roles)
// ============================================================

enum ActivityCategory {
  AUTH        // login / logout / register / password / 2FA
  ACCOUNT     // user / teknisi / store profile changes
  ORDER       // imei, server, marketplace, topup orders
  PAYMENT     // wallet deposit, refund, escrow, withdrawal
  COMMUNICATION // chat / konsultasi / remote
  ADMIN       // admin action: approve / deposit / config
  SECURITY    // suspicious activity, blocked attempts
  SYSTEM      // background workers, automated state changes
}

enum ActivitySeverity {
  INFO
  SUCCESS
  WARNING
  CRITICAL
}

model ActivityLog {
  id         String           @id @default(cuid())
  /// Stable code — e.g. "auth.login", "order.imei.created", "payment.deposit.manual"
  action     String
  category   ActivityCategory @default(SYSTEM)
  severity   ActivitySeverity @default(INFO)
  /// Human-friendly summary (Indonesian) shown in the table.
  summary    String           @db.Text
  /// Optional richer description (multi-line ok).
  detail     String?          @db.Text

  // Actor (who did the action) — nullable so anonymous events still log.
  actorId    String?
  actorName  String?
  actorEmail String?
  actorRole  UserRole?

  // Target (what / who was affected). Generic to support orders, users, conversations, …
  targetType String?
  targetId   String?
  targetLabel String?

  // Request context
  ip         String?
  userAgent  String?          @db.Text

  /// Free-form structured payload (e.g. amount, orderCode, fromStatus → toStatus).
  metadata   Json?

  createdAt  DateTime         @default(now())

  actor      User?            @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([category, createdAt(sort: Desc)])
  @@index([severity, createdAt(sort: Desc)])
  @@index([actorId, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
}
