// ============================================================
// REKBER (ESCROW)
// ============================================================

enum RekberStatus {
  PENDING
  HELD
  PROCESSING
  SHIPPED
  RELEASED
  DISPUTED
  REFUNDED
}

model RekberTransaction {
  id          String       @id @default(cuid())
  orderCode   String       @unique
  buyerId     String
  sellerId    String
  amount      Decimal      @db.Decimal(12, 0)
  fee         Decimal      @default(0) @db.Decimal(12, 0)
  status      RekberStatus @default(PENDING)
  description String?      @db.Text
  note        String?      @db.Text
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  heldAt      DateTime?
  processedAt DateTime?
  shippedAt   DateTime?
  releasedAt  DateTime?
  disputedAt  DateTime?
  refundedAt  DateTime?

  shippingCourier         ShippingCourier?
  trackingNumber          String?
  trackingSummaryStatus   String?
  trackingSummaryDesc     String?          @db.Text
  trackingLastEventAt     DateTime?
  trackingLastSyncedAt    DateTime?
  trackingNextSyncAt      DateTime?
  trackingActive          Boolean          @default(false)
  trackingSyncFailures    Int              @default(0)

  inspectionOrderId String? @unique
  inspectionOrder   InspectionOrder? @relation(fields: [inspectionOrderId], references: [id], onDelete: SetNull)

  buyer          User                  @relation("RekberBuyer", fields: [buyerId], references: [id])
  seller         User                  @relation("RekberSeller", fields: [sellerId], references: [id])
  complaint      RekberComplaint?
  packagingProof RekberPackagingProof?
}

model RekberPackagingProof {
  id               String                    @id @default(cuid())
  rekberId         String                    @unique
  sellerId         String
  status           OrderPackagingProofStatus @default(PENDING)
  rejectionNote    String?                   @db.Text
  submittedAt      DateTime?
  rejectedAt       DateTime?
  resubmitDeadline DateTime?
  reviewedAt       DateTime?
  reviewedById     String?
  slaNotifiedAt    DateTime?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  rekber     RekberTransaction      @relation(fields: [rekberId], references: [id], onDelete: Cascade)
  seller     User                   @relation("RekberSellerPackagingProofs", fields: [sellerId], references: [id])
  reviewedBy User?                  @relation("RekberAdminPackagingReviews", fields: [reviewedById], references: [id])
  media      RekberPackagingMedia[]

  @@index([status, submittedAt])
  @@index([status, resubmitDeadline])
}

model RekberPackagingMedia {
  id        String                  @id @default(cuid())
  proofId   String
  type      OrderPackagingMediaType
  url       String
  mimeType  String
  sizeBytes Int
  createdAt DateTime                @default(now())

  proof RekberPackagingProof @relation(fields: [proofId], references: [id], onDelete: Cascade)

  @@index([proofId])
}

enum RekberComplaintStatus {
  OPEN
  SELLER_RESPONDED
  ESCALATED
  RESOLVED
  WITHDRAWN
}

model RekberComplaint {
  id                String                    @id @default(cuid())
  rekberId          String                    @unique
  buyerId           String
  sellerId          String
  reason            String                    @db.Text
  status            RekberComplaintStatus     @default(OPEN)
  sellerResponse    String?                   @db.Text
  sellerRespondedAt DateTime?
  escalatedAt       DateTime?
  resolvedAt        DateTime?
  resolution        OrderComplaintResolution?
  refundAmount      Decimal?                  @db.Decimal(12, 0)
  adminNote         String?                   @db.Text
  adminId           String?
  sellerDeadline    DateTime
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  rekber RekberTransaction @relation(fields: [rekberId], references: [id], onDelete: Cascade)
  buyer  User              @relation("RekberBuyerComplaints", fields: [buyerId], references: [id])
  seller User              @relation("RekberSellerComplaints", fields: [sellerId], references: [id])
  admin  User?             @relation("RekberAdminComplaintResolutions", fields: [adminId], references: [id])
  media  RekberComplaintMedia[]

  @@index([status, sellerDeadline])
  @@index([status, escalatedAt])
}

model RekberComplaintMedia {
  id          String                  @id @default(cuid())
  complaintId String
  type        OrderComplaintMediaType
  url         String
  mimeType    String
  sizeBytes   Int
  createdAt   DateTime                @default(now())

  complaint RekberComplaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)

  @@index([complaintId])
}

