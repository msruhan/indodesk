// ============================================================
// ACTIVITY LOG (audit trail across all roles)
// ============================================================

enum ActivityCategory {
  AUTH        // login / logout / register / password / 2FA
  ACCOUNT     // user / teknisi / store profile changes
  ORDER       // imei, server, marketplace, topup orders
  PAYMENT     // wallet deposit, refund, escrow, withdrawal
  COMMUNICATION // chat / konsultasi / remote
  ADMIN       // admin action: approve / deposit / config
  SECURITY    // suspicious activity, blocked attempts
  SYSTEM      // background workers, automated state changes
}

enum ActivitySeverity {
  INFO
  SUCCESS
  WARNING
  CRITICAL
}

model ActivityLog {
  id         String           @id @default(cuid())
  /// Stable code — e.g. "auth.login", "order.imei.created", "payment.deposit.manual"
  action     String
  category   ActivityCategory @default(SYSTEM)
  severity   ActivitySeverity @default(INFO)
  /// Human-friendly summary (Indonesian) shown in the table.
  summary    String           @db.Text
  /// Optional richer description (multi-line ok).
  detail     String?          @db.Text

  // Actor (who did the action) — nullable so anonymous events still log.
  actorId    String?
  actorName  String?
  actorEmail String?
  actorRole  UserRole?

  // Target (what / who was affected). Generic to support orders, users, conversations, …
  targetType String?
  targetId   String?
  targetLabel String?

  // Request context
  ip         String?
  userAgent  String?          @db.Text

  /// Free-form structured payload (e.g. amount, orderCode, fromStatus → toStatus).
  metadata   Json?

  createdAt  DateTime         @default(now())

  actor      User?            @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([category, createdAt(sort: Desc)])
  @@index([severity, createdAt(sort: Desc)])
  @@index([actorId, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
}

// ============================================================
// SUPPORT TICKETS (Lapor Kendala)
// ============================================================

enum SupportTicketReporterRole {
  USER
  TEKNISI
}

enum SupportTicketCategory {
  SERVICE_ISSUE
  KONSULTASI
  INSPEKSI
  MARKETPLACE
  ACCOUNT_SECURITY
  PLATFORM_BUG
  OTHER
}

enum SupportTicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_REPORTER
  RESOLVED
}

enum SupportTicketRelatedType {
  KONSULTASI
  REMOTE
  INSPEKSI
  MARKETPLACE_ORDER
  OTHER
}

enum SupportTicketMediaKind {
  IMAGE
  VIDEO
}

enum SupportTicketAuthorRole {
  USER
  TEKNISI
  ADMIN
}

model SupportTicket {
  id                String                    @id @default(cuid())
  publicId          String                    @unique
  reporterId        String
  reporterRole      SupportTicketReporterRole
  category          SupportTicketCategory
  priority          SupportTicketPriority     @default(NORMAL)
  status            SupportTicketStatus       @default(OPEN)
  subject           String
  description       String                    @db.Text
  relatedType       SupportTicketRelatedType?
  relatedId         String?
  relatedLabel      String?
  relatedManualNote String?                   @db.Text
  relatedSnapshot   Json?
  previousTicketId  String?
  assignedAdminId   String?
  resolvedAt        DateTime?
  lastMessageAt     DateTime                  @default(now())
  reporterUnread    Boolean                   @default(false)
  adminUnread       Boolean                   @default(true)
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  reporter       User                   @relation("TicketReporter", fields: [reporterId], references: [id])
  assignedAdmin  User?                  @relation("TicketAssignee", fields: [assignedAdminId], references: [id], onDelete: SetNull)
  previousTicket SupportTicket?         @relation("TicketFollowUp", fields: [previousTicketId], references: [id], onDelete: SetNull)
  followUpTickets SupportTicket[]       @relation("TicketFollowUp")
  messages       SupportTicketMessage[]
  media          SupportTicketMedia[]

  @@index([status, lastMessageAt(sort: Desc)])
  @@index([reporterId, createdAt(sort: Desc)])
  @@index([adminUnread, priority, lastMessageAt(sort: Desc)])
  @@index([assignedAdminId])
}

model SupportTicketMessage {
  id         String                  @id @default(cuid())
  ticketId   String
  authorId   String
  authorRole SupportTicketAuthorRole
  body       String                  @db.Text
  isInternal Boolean                 @default(false)
  createdAt  DateTime                @default(now())

  ticket SupportTicket        @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author User                   @relation(fields: [authorId], references: [id])
  media  SupportTicketMedia[]

  @@index([ticketId, createdAt])
}

model SupportTicketMedia {
  id        String                 @id @default(cuid())
  ticketId  String
  messageId String?
  kind      SupportTicketMediaKind
  url       String                 @db.Text
  fileName  String
  mimeType  String
  sizeBytes Int
  createdAt DateTime               @default(now())

  ticket  SupportTicket         @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  message SupportTicketMessage? @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}
