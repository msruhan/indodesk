  image      String   @db.Text
  link       String   @db.Text
  buttonText String   @default("Lihat")
  active     Boolean  @default(true)
  sortOrder  Int      @default(0)
  /// marketplace | shop | topup
  placement  String   @default("marketplace")
  createdAt  DateTime @default(now())
