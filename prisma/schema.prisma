// ============================================================
// IMEI SERVICE — API Manager, Service Groups, Services, Orders
// ============================================================

enum ImeiApiStatus {
  ACTIVE
  INACTIVE
}

enum ImeiServiceStatus {
  ACTIVE
  INACTIVE
}

enum ImeiOrderStatus {
  PENDING
  IN_PROCESS
  SUCCESS
  REJECTED
  CANCELLED
}

/// API Provider/Supplier (e.g. DhruFusion, UnlockBase)
model ImeiApi {
  id        String        @id @default(cuid())
  title     String
  host      String
  username  String
  apiKey    String        @db.Text
  apiType   String        @default("DhruFusion") // DhruFusion | UnlockBase | Custom
  libraryId Int           @default(1)
  status    ImeiApiStatus @default(ACTIVE)
  notes     String?       @db.Text
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  services       ImeiService[]
  serverServices ServerService[]

  @@index([status])
}

/// Service Group (Network/Category) — e.g. "Samsung Unlock", "iPhone iCloud"
model ImeiServiceGroup {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  services ImeiService[]
}

/// Individual IMEI Service (a "method" in DhruFusion terminology)
model ImeiService {
  id           String            @id @default(cuid())
  apiId        String
  groupId      String
  toolId       String? // external tool/service ID from supplier
  title        String
  description  String?           @db.Text
  price        Decimal           @db.Decimal(12, 0) // IDR
  deliveryTime String? // e.g. "1-24 jam"
  status       ImeiServiceStatus @default(ACTIVE)

  // Required fields (from DhruFusion API spec)
  requiresImei     Boolean @default(true)
  requiresNetwork  Boolean @default(false)
  requiresModel    Boolean @default(false)
  requiresProvider Boolean @default(false)
  requiresPin      Boolean @default(false)
  requiresKbh      Boolean @default(false)
  requiresMep      Boolean @default(false)
  requiresPrd      Boolean @default(false)
  requiresSn       Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  api    ImeiApi          @relation(fields: [apiId], references: [id], onDelete: Cascade)
  group  ImeiServiceGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  orders ImeiOrder[]

  @@index([groupId, status])
  @@index([apiId])
}

/// IMEI Order placed by user
model ImeiOrder {
  id        String          @id @default(cuid())
  orderCode String          @unique // e.g. "IMEI-2026-XXXXXX"
  userId    String
  serviceId String
  imei      String
  price     Decimal         @db.Decimal(12, 0)
  status    ImeiOrderStatus @default(PENDING)

  // Optional input fields
  network      String?
  model        String?
  provider     String?
  pin          String?
  kbh          String?
  mep          String?
  prd          String?
  serialNumber String?
  note         String? @db.Text

  // Result fields
  code        String? @db.Text // unlock code / result
  comments    String? @db.Text // admin/system comments
  referenceId String? // external supplier reference ID

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  processedAt DateTime?
  completedAt DateTime?

  user    User        @relation(fields: [userId], references: [id])
  service ImeiService @relation(fields: [serviceId], references: [id])

  @@index([userId, status])
  @@index([status, createdAt])
  @@index([imei])
}

// ============================================================
// SERVER SERVICE — Server-based unlock/flash services
// ============================================================

enum ServerOrderStatus {
  PENDING
  IN_PROCESS
  SUCCESS
  REJECTED
  CANCELLED
}

/// Server Box — grouping for server services (e.g. "Samsung Server", "iPhone Server")
model ServerServiceBox {
  id        String   @id @default(cuid())
  title     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  services ServerService[]
}

/// Individual Server Service
model ServerService {
  id             String            @id @default(cuid())
  apiId          String
  boxId          String
  toolId         String? // external tool ID from supplier
  title          String
  description    String?           @db.Text
  price          Decimal           @db.Decimal(12, 0)
  deliveryTime   String?
  quantity       Int               @default(1)
  requiredFields String?           @db.Text // JSON schema of required input fields
  status         ImeiServiceStatus @default(ACTIVE)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  api    ImeiApi          @relation(fields: [apiId], references: [id], onDelete: Cascade)
  box    ServerServiceBox @relation(fields: [boxId], references: [id], onDelete: Cascade)
  orders ServerOrder[]

  @@index([boxId, status])
  @@index([apiId])
}

/// Server Order placed by user
model ServerOrder {
  id             String            @id @default(cuid())
  orderCode      String            @unique
  userId         String
  serviceId      String
  price          Decimal           @db.Decimal(12, 0)
  status         ServerOrderStatus @default(PENDING)
  requiredFields String?           @db.Text // JSON of user-submitted field values
  email          String?
  notes          String?           @db.Text
  code           String?           @db.Text // result
  comments       String?           @db.Text
  referenceId    String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  processedAt    DateTime?
  completedAt    DateTime?

  user    User          @relation(fields: [userId], references: [id])
  service ServerService @relation(fields: [serviceId], references: [id])

  @@index([userId, status])
  @@index([status, createdAt])
}

// ============================================================
// PLATFORM NOTIFICATIONS (bell popup — shared across roles)
// ============================================================

model PlatformNotification {
  id        String   @id @default(cuid())
  title     String
  body      String   @db.Text
  audiences Json // ["USER","TEKNISI","ADMIN"]
  tone      String   @default("primary")
  icon      String   @default("bell")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, createdAt(sort: Desc)])
