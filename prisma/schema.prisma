enum PaymentIntentPurpose {
  WALLET_TOPUP
  KONSULTASI
  MARKETPLACE
  CATALOG_TOPUP
}

enum PaymentIntentStatus {
  UNPAID
  PAID
  EXPIRED
  FAILED
  REFUNDED
}

model PaymentIntent {
  id              String               @id @default(cuid())
  merchantRef     String               @unique
  purpose         PaymentIntentPurpose
  userId          String
  targetId        String?
  subtotal        Decimal              @db.Decimal(14, 0)
  feeAmount       Decimal              @default(0) @db.Decimal(14, 0)
