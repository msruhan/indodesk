  updatedAt DateTime @updatedAt
}

// ============================================================
// LANDING PRICING (admin-managed plans for homepage)
// ============================================================

model LandingPricingPlan {
  id           String   @id @default(cuid())
  name         String
  description  String   @default("") @db.Text
