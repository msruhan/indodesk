// ============================================================
// IndoTeknizi — Prisma Schema
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// AUTH.JS MODELS (required by @auth/prisma-adapter)
// ============================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model TelegramVerification {
  id        String   @id @default(cuid())
  userId    String
  code      String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([code, expiresAt])
}

// ============================================================
// USER & ROLES
// ============================================================

enum UserRole {
  ADMIN
  TEKNISI
  USER
}

enum TeknisiVerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String? // hashed with bcrypt (null for OAuth-only users)
  role          UserRole  @default(USER)
  isActive           Boolean   @default(true)
  phone              String?
  address            String?
  shippingCityId         String?
  shippingCityLabel      String?
  shippingDistrictId     String?
  shippingDistrictLabel  String?
  shippingLocationId     String?
  shippingLocationLabel  String?
  shippingStreet         String?
  twoFactorEnabled   Boolean   @default(false)
  twoFactorSecret    String?   @db.Text
  passwordChangedAt  DateTime?
  mustChangePassword Boolean   @default(false)
  sessionVersion     Int       @default(0)
  lockedUntil        DateTime?
  walletPolicyOverride Json?
  telegramUserId     String?   @unique // Telegram user ID for notifications
  telegramUsername   String?   // Telegram username (optional)
  telegramChatId     String?   // Telegram chat ID for sending messages
  telegramLinkedAt   DateTime? // When Telegram was linked
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Relations
  accounts         Account[]
  sessions         Session[]
  passwordResetTokens PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  userSessions       UserSession[]
  backupCodes        BackupCode[]
  telegramLinkTokens TelegramLinkToken[]
  teknisiProfile   TeknisiProfile?
  products         Product[]
  ordersAsBuyer    Order[]               @relation("BuyerOrders")
  ordersAsSeller   Order[]               @relation("SellerOrders")
  wallet           Wallet?
  rekberAsBuyer    RekberTransaction[]   @relation("RekberBuyer")
  rekberAsSeller   RekberTransaction[]   @relation("RekberSeller")
  topupOrders      TopupOrder[]
  konsultasiAsUser KonsultasiSession[]   @relation("KonsultasiUser")
  konsultasiAsTech KonsultasiSession[]   @relation("KonsultasiTeknisi")
  lowonganPosted   Lowongan[]
  applications     LowonganApplication[]
  remoteAsUser     RemoteSession[]       @relation("RemoteUser")
  remoteAsTech     RemoteSession[]       @relation("RemoteTeknisi")
  imeiOrders       ImeiOrder[]
  serverOrders     ServerOrder[]
  chatAsUser       ChatConversation[]    @relation("ChatAsUser")
  chatAsTeknisi    ChatConversation[]    @relation("ChatAsTeknisi")
  chatMessagesSent ChatMessage[]
  teknisiStore              TeknisiStore?
  activityLogs              ActivityLog[]
  teknisiReviewsReceived    TeknisiReview[] @relation("TeknisiReviewsReceived")
  teknisiReviewsAuthored    TeknisiReview[] @relation("TeknisiReviewsAuthored")
  teknisiPortfolioCases     TeknisiPortfolioCase[] @relation("TeknisiPortfolioCases")
  teknisiCertifications     TeknisiCertification[] @relation("TeknisiCertifications")
  inspectionOrdersAsUser  InspectionOrder[]      @relation("InspectionUser")
  inspectionOrdersAsTech  InspectionOrder[]      @relation("InspectionTeknisi")
  telegramVerifications   TelegramVerification[]
  productReviewsAuthored  ProductReview[]        @relation("ProductReviewsAuthored")
  walletDepositRequestsTarget  WalletDepositRequest[] @relation("WalletDepositTarget")
  walletDepositRequestsAuthored WalletDepositRequest[] @relation("WalletDepositRequester")
  walletWithdrawRequests       WalletWithdrawRequest[]
  walletWithdrawOtps           WalletWithdrawOtp[]
  walletSecurityAlerts         WalletSecurityAlert[]  @relation("WalletSecurityAlertUser")
  buyerComplaints              OrderComplaint[]       @relation("BuyerComplaints")
  sellerComplaints             OrderComplaint[]       @relation("SellerComplaints")
  adminComplaintResolutions    OrderComplaint[]       @relation("AdminComplaintResolutions")
  rekberBuyerComplaints        RekberComplaint[]      @relation("RekberBuyerComplaints")
  rekberSellerComplaints       RekberComplaint[]      @relation("RekberSellerComplaints")
  rekberAdminComplaintResolutions RekberComplaint[]   @relation("RekberAdminComplaintResolutions")
  packagingProofsAsSeller    OrderPackagingProof[]  @relation("SellerPackagingProofs")
  packagingProofsReviewed      OrderPackagingProof[]  @relation("AdminPackagingReviews")
  rekberPackagingProofsAsSeller RekberPackagingProof[] @relation("RekberSellerPackagingProofs")
  rekberPackagingProofsReviewed RekberPackagingProof[] @relation("RekberAdminPackagingReviews")
  supportTicketsReported     SupportTicket[]        @relation("TicketReporter")
  supportTicketsAssigned     SupportTicket[]        @relation("TicketAssignee")
  supportTicketMessages      SupportTicketMessage[]
  paymentIntents             PaymentIntent[]        @relation("UserPaymentIntents")
}

// ============================================================
// SECURITY HARDENING — TOKENS / SESSIONS / BACKUP CODES
// ============================================================

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique // sha256(token)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique // sha256(token)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model UserSession {
  id               String   @id @default(cuid())
  userId           String
  deviceLabel      String?
  ip               String?
  userAgent        String?
  fingerprint      String?
  sessionTokenHash String   @unique
  createdAt        DateTime @default(now())
  lastSeenAt       DateTime @default(now())
  revokedAt        DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
}

model BackupCode {
  id        String   @id @default(cuid())
  userId    String
  codeHash  String   // bcrypt hash
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt])
}

model TelegramLinkToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique // sha256(token)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// ============================================================
// TEKNISI PROFILE (extends User where role = TEKNISI)
// ============================================================

model TeknisiProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  specialty       String[] // e.g. ["Unlock", "Flashing", "Root"]
  experience      String? // e.g. "8 tahun"
  coverImage      String? // banner profil publik
  location        String?
  shipOriginCityId        String?
  shipOriginCityLabel     String?
  shipOriginDistrictId    String?
  shipOriginDistrictLabel String?
  shipOriginLocationId    String?
  shipOriginLocationLabel String?
  shipOriginStreet        String?
  /** Kode kurir BinderByte yang dipakai penjual (mis. jne, jnt). Pembeli hanya bisa pilih dari daftar ini. */
  shipOriginCouriers      String[] @default([])
  description     String?  @db.Text
  tagline         String?  @db.Text
  issuesHandled   String?  @db.Text
  brandFocus      String?  @db.Text
  workApproach    String?  @db.Text
  serviceScope    String[]             @default([])
  languages       String[]             @default([])
  secondarySkills String[]             @default([])
  operatingHours  Json                 @default("{}")
  consultationServices Json            @default("[]")
  rating          Decimal  @default(0) @db.Decimal(3, 2)
  reviewCount     Int      @default(0)
  totalKonsultasi Int      @default(0)
  totalView       Int      @default(0)
  responseTime    String? // e.g. "< 5 menit"
  completionRate  Int      @default(0) // percentage
  isOnline            Boolean                   @default(false)
  isVerified          Boolean                   @default(false)
  providesInspection  Boolean                   @default(false) // Teknisi menyediakan layanan inspeksi HP/Laptop
  inspectionPriceOnline  Decimal? @db.Decimal(12, 0) // tarif inspeksi online (video call) IDR
  inspectionPriceOffline Decimal? @db.Decimal(12, 0) // tarif inspeksi offline (on-site) IDR
  verificationStatus  TeknisiVerificationStatus @default(PENDING)
  rejectionReason     String?                   @db.Text
  applicationData     Json                      @default("{}")
  price               Decimal                   @default(0) @db.Decimal(12, 0) // starting price IDR
  telegramChatId      String?                   @unique // Telegram chat ID untuk notifikasi
  telegramUsername    String? // Telegram username (tanpa @)
  telegramLinkedAt    DateTime? // Waktu sinkronisasi Telegram
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================================
// TEKNISI REVIEWS (ulasan profil teknisi dari user terdaftar / Google)
// ============================================================

model TeknisiReview {
  id        String   @id @default(cuid())
  teknisiId String
  authorId  String
  rating    Int // 1–5
  tag       String?
  comment   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teknisi User @relation("TeknisiReviewsReceived", fields: [teknisiId], references: [id], onDelete: Cascade)
  author  User @relation("TeknisiReviewsAuthored", fields: [authorId], references: [id], onDelete: Cascade)

  @@unique([teknisiId, authorId])
  @@index([teknisiId, createdAt(sort: Desc)])
}

// ============================================================
// TEKNISI PORTFOLIO (case highlights di profil publik)
// ============================================================

model TeknisiPortfolioCase {
  id        String   @id @default(cuid())
  teknisiId String
  title     String
  meta      String
  result    String
  imageUrl  String? // foto aktivitas servis
  icon      String // smartphone | wrench | laptop
  tone      String // tailwind gradient e.g. from-primary-500 to-emerald-600
  glow      String // rgba glow for hover effects
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teknisi User @relation("TeknisiPortfolioCases", fields: [teknisiId], references: [id], onDelete: Cascade)

  @@index([teknisiId, sortOrder])
}

// ============================================================
// TEKNISI CERTIFICATIONS (sertifikat di profil publik)
// ============================================================

model TeknisiCertification {
  id        String   @id @default(cuid())
  teknisiId String
  title     String
  fileUrl   String
  fileType  String // image | pdf
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teknisi User @relation("TeknisiCertifications", fields: [teknisiId], references: [id], onDelete: Cascade)

  @@index([teknisiId, sortOrder])
}

// ============================================================
// TEKNISI STORE (Toko handphone — 1 per teknisi)
// ============================================================

model TeknisiStore {
  id            String               @id @default(cuid())
  userId        String               @unique
  name          String
  city          String?
  address       String?
  phone         String?
  email         String?
  instagram     String?
  threads       String?
  tiktok        String?
  shipOriginLocationId    String?
  shipOriginLocationLabel String?
  shipOriginCityId        String?
  shipOriginCityLabel     String?
  shipOriginDistrictId    String?
  shipOriginDistrictLabel String?
  shipOriginStreet        String?
  jamWeekdays   String?
  jamWeekend    String?
  operatingHours Json                 @default("{}")
  profileImage  String? // avatar toko (listing & kartu penjual)
  coverImage    String?
  gallery       String[]             @default([])
  layanan       String[]             @default([])
  journeyIntro  String?
  journey       Json                 @default("[]")
  badge         String?
  listingStatus ProductListingStatus @default(APPROVED)
  isPublished   Boolean              @default(false)
  profileViews  Int                  @default(0)
  totalSold     Int                  @default(0)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isPublished, listingStatus])
}

// ============================================================
// MARKETPLACE — PRODUCTS & ORDERS
// ============================================================

enum ProductCategory {
  IPHONE
  ANDROID
  IPAD
  MACBOOK
  LAPTOP
  PC
  AKSESORIS
  SOFTWARE
  LAINNYA
}

/// Sub-kategori device untuk HANDPHONE & TABLET — menentukan apakah punya 3uTools (Apple)
enum DeviceType {
  IPHONE
  ANDROID_PHONE
  IPAD
  ANDROID_TABLET
}

/// Grade kondisi terstruktur untuk penilaian benchmark objektif
enum ConditionGrade {
  BNIB      // Brand New In Box (segel)
  LIKE_NEW  // Like New (99%)
  MULUS     // Mulus (95%+)
  NORMAL    // Normal (tanda pakai wajar)
  MINUS     // Ada minus (lecet/dent)
}

enum ProductListingStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

enum ProductWarranty {
  NONE
  OFFICIAL
  STORE
}

enum ProductCouponDiscountType {
  PERCENT
  FIXED
}

enum ProductSaleCondition {
  NEW
  USED
}

model Product {
  id             String               @id @default(cuid())
  sellerId       String
  name           String
  category       ProductCategory
  deviceType     DeviceType?          // diisi untuk HANDPHONE & TABLET
  price          Decimal              @db.Decimal(12, 0)
  description    String?              @db.Text
  color          String               @default("")
  ram            String               @default("")
  processor      String               @default("")
  storage        String               @default("")
  warranty       ProductWarranty      @default(NONE)
  completeness   Json                 @default("[]")
  image          String?
  images         Json                 @default("[]")
  // Screenshot 3uTools (bukti kualitas hardware iPhone/iPad)
  threeUtoolsImages Json              @default("[]") // Array URL screenshot 3uTools

  // ---- Kondisi terstruktur (untuk benchmark objektif) ----
  /** Baru vs bekas — produk baru otomatis benchmark sempurna tanpa 3uTools. */
  saleCondition  ProductSaleCondition   @default(USED)
  conditionGrade   ConditionGrade?
  conditionPercent Int?               // 0-100, estimasi kondisi fisik
  minusNotes       String?            @db.Text

  // ---- Data 3uTools terstruktur (khusus IPHONE/IPAD) ----
  batteryHealth    Int?               // 0-100
  batteryCycle     Int?               // cycle count
  isAllOriginal    Boolean?           // semua part original?
  replacedParts    String[]           @default([]) // part yang diganti
  trueToneActive   Boolean?           // True Tone aktif?
  faceIdWorks      Boolean?           // Face ID normal?
  verified3uTools  Boolean            @default(false) // sudah verifikasi screenshot 3uTools?

  rating         Decimal              @default(0) @db.Decimal(3, 2)
  reviewCount    Int                  @default(0)
  views          Int                  @default(0)
  soldCount      Int                  @default(0)
  stock          Int                  @default(1)
  /** Berat produk (kg) untuk perhitungan ongkir — diisi penjual. */
  weightKg       Decimal              @default(1) @db.Decimal(6, 2)
  listingStatus  ProductListingStatus @default(DRAFT)
  isPublished    Boolean              @default(false)
  /** Ringkasan singkat perubahan terakhir yang menunggu review admin. */
  pendingChangeSummary String?        @db.Text
  couponCode             String?
  couponDiscountType     ProductCouponDiscountType?
  couponDiscountValue    Decimal?             @db.Decimal(12, 0)
  isActive       Boolean              @default(true)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  seller     User            @relation(fields: [sellerId], references: [id])
  orderItems OrderItem[]
  reviews    ProductReview[]
}

// ============================================================
// MARKETPLACE PRODUCT REVIEWS (ulasan pembeli setelah order selesai)
// ============================================================

model ProductReview {
  id        String   @id @default(cuid())
  productId String
  orderId   String
  authorId  String
  rating    Int // 1–5
  comment   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  author  User    @relation("ProductReviewsAuthored", fields: [authorId], references: [id], onDelete: Cascade)

  @@unique([orderId, productId])
  @@index([productId, createdAt(sort: Desc)])
  @@index([authorId])
}

enum OrderStatus {
  AWAITING_PAYMENT
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DISPUTED
  COMPLETED
  CANCELLED
  REFUNDED
}

enum OrderCancelledBy {
  SELLER
  ADMIN
  SYSTEM
}

enum OrderComplaintStatus {
  OPEN
  SELLER_RESPONDED
  AWAITING_RETURN
  RETURN_SHIPPED
  AWAITING_SELLER_CONFIRM
  ESCALATED
  RESOLVED
  WITHDRAWN
  RETURN_EXPIRED
}

enum OrderComplaintType {
  RETURN_REQUIRED
}

enum OrderComplaintResolution {
  REFUND_FULL
  REFUND_PARTIAL
  REJECTED
}

enum OrderComplaintMediaType {
  PHOTO
  VIDEO
  UNBOXING_VIDEO
  DEFECT_PHOTO
  RETURN_PHOTO
  RETURN_VIDEO
  RETURN_REJECT_PHOTO
}

enum OrderPackagingProofStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OrderPackagingMediaType {
  PHOTO
  VIDEO
}

/// Kode kurir — dipetakan ke BinderByte (`jne`, `jnt`, …)
enum ShippingCourier {
  JNE
  POS
  JNT
  SICEPAT
  TIKI
  ANTERAJA
  WAHANA
  NINJA
  LION
}

enum ShippingLocationType {
  PROVINCE
  CITY
  DISTRICT
  VILLAGE
}

enum OrderPaymentMethod {
  WALLET
  PAYMENT_GATEWAY
}

model Order {
  id        String      @id @default(cuid())
  orderCode String      @unique // e.g. "ORD-2026-XXXXXX"
  buyerId   String
  sellerId  String
  subtotal  Decimal     @db.Decimal(12, 0)
  fee       Decimal     @default(0) @db.Decimal(12, 0)
  discount  Decimal     @default(0) @db.Decimal(12, 0)
  total     Decimal     @db.Decimal(12, 0)
  buyerFeeAmount    Decimal           @default(0) @db.Decimal(12, 0)
  sellerFeeAmount   Decimal           @default(0) @db.Decimal(12, 0)
  buyerHoldAmount   Decimal           @default(0) @db.Decimal(12, 0)
  sellerNetAmount   Decimal           @default(0) @db.Decimal(12, 0)
  settlementVersion Int               @default(2)
  cancelReason      String?           @db.Text
  cancelledBy       OrderCancelledBy?
  paymentMethod     OrderPaymentMethod?
  pgProvider        String?
  pgExternalRef     String?
  checkoutBatchId   String?
  paymentExpiresAt  DateTime?
  status    OrderStatus @default(PENDING)
  note      String?
  shippingAddress       String?   @db.Text
  shippingPhone         String?
  shippingLocationId    String?
  shippingCost          Decimal   @default(0) @db.Decimal(12, 0)
  shippingService       String?
  checkoutShippingCourier String?
  completedAt           DateTime?
  deliveredAt           DateTime?
  buyerActionDeadline   DateTime?
  autoCompletedAt       DateTime?

  shippingCourier       ShippingCourier?
  trackingNumber        String?
  trackingSummaryStatus String?
  trackingSummaryDesc   String?          @db.Text
  trackingLastEventAt   DateTime?
  trackingLastSyncedAt  DateTime?
  trackingNextSyncAt    DateTime?
  trackingActive        Boolean          @default(false)
  trackingSyncFailures  Int              @default(0)
  shippedAt             DateTime?

  shippingLabelToken       String?   @unique
  shippingLabelGeneratedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  buyer          User                 @relation("BuyerOrders", fields: [buyerId], references: [id])
  seller         User                 @relation("SellerOrders", fields: [sellerId], references: [id])
  items          OrderItem[]
  trackingEvents OrderTrackingEvent[]
  reviews        ProductReview[]
  complaint      OrderComplaint?
  packagingProof OrderPackagingProof?

  @@index([trackingActive, trackingNextSyncAt])
  @@index([status, trackingActive])
  @@index([status, buyerActionDeadline])
  @@index([checkoutBatchId, status])
  @@index([pgExternalRef])
  @@index([status, paymentExpiresAt])
}

model ShippingLocation {
  id           String               @id
  type         ShippingLocationType
  code         String
  name         String
  label        String
  parentId     String?
  binderbyteId String?
  postalCode   String?
  sortOrder    Int                  @default(0)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@unique([type, code])
  @@index([type, parentId])
  @@index([parentId, sortOrder])
  @@index([type, name])
}

model OrderComplaint {
  id                String                    @id @default(cuid())
  orderId           String                    @unique
  buyerId           String
  sellerId          String
  reason            String                    @db.Text
  type              OrderComplaintType        @default(RETURN_REQUIRED)
  status            OrderComplaintStatus      @default(OPEN)
  sellerResponse    String?                   @db.Text
  sellerRespondedAt DateTime?
  escalatedAt       DateTime?
  resolvedAt        DateTime?
  resolution        OrderComplaintResolution?
  refundAmount      Decimal?                  @db.Decimal(12, 0)
  adminNote         String?                   @db.Text
  adminId           String?
  sellerDeadline    DateTime
  returnDeadline        DateTime?
  returnShippedAt       DateTime?
  returnDeliveredAt     DateTime?
  sellerConfirmDeadline DateTime?
  returnCourier         ShippingCourier?
  returnTrackingNumber  String?
  returnTrackingActive  Boolean               @default(false)
  returnSummaryStatus   String?
  returnLastSyncedAt    DateTime?
  returnNextSyncAt      DateTime?
  returnSyncFailures    Int                   @default(0)
  sellerReturnRejectReason String?            @db.Text
  sellerReturnRejectedAt   DateTime?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  order          Order                      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  buyer          User                       @relation("BuyerComplaints", fields: [buyerId], references: [id])
  seller         User                       @relation("SellerComplaints", fields: [sellerId], references: [id])
  admin          User?                      @relation("AdminComplaintResolutions", fields: [adminId], references: [id])
  media          OrderComplaintMedia[]
  returnTrackingEvents OrderReturnTrackingEvent[]

  @@index([status, sellerDeadline])
  @@index([status, escalatedAt])
  @@index([status, returnDeadline])
  @@index([status, sellerConfirmDeadline])
  @@index([returnTrackingActive, returnNextSyncAt])
}

model OrderReturnTrackingEvent {
  id          String   @id @default(cuid())
  complaintId String
  occurredAt  DateTime
  description String   @db.Text
  location    String?
  createdAt   DateTime @default(now())

  complaint OrderComplaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)

  @@index([complaintId, occurredAt])
}

model OrderComplaintMedia {
  id          String                  @id @default(cuid())
  complaintId String
  type        OrderComplaintMediaType
  url         String
  mimeType    String
  sizeBytes   Int
  createdAt   DateTime                @default(now())

  complaint OrderComplaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)

  @@index([complaintId])
}

model OrderPackagingProof {
  id               String                    @id @default(cuid())
  orderId          String                    @unique
