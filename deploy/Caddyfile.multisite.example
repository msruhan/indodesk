# Contoh Caddyfile multi-site: Nexus + IndoTeknizi di VPS yang sama.
# Lokasi di server: /opt/nexus-server/deploy/Caddyfile
#
# Ganti domain dan hostname container sesuai `docker ps`.
# IndoTeknizi app harus join network yang sama dengan Caddy (lihat docker-compose.production.yml).

# --- Nexus (customer shop) ---
nexus.example.com {
	reverse_proxy app:3000
}

# --- Bantoo (marketplace) ---
bantoo.in {
	reverse_proxy indoteknizi-app-1:3000
}

www.bantoo.in {
	redir https://bantoo.in{uri} permanent
}
