# IndoTeknizi — template env production untuk VPS (/opt/indoteknizi/.env.production)
# Salin: cp deploy/env.production.template .env.production
# Generate secrets: openssl rand -base64 32

# --- App URL (wajib sesuaikan domain) ---
NEXT_PUBLIC_APP_URL="https://bantoo.in"
AUTH_URL="https://bantoo.in"
AUTH_TRUST_HOST=true

# --- Auth / crypto (generate baru untuk production) ---
AUTH_SECRET="CHANGE_ME_openssl_rand_base64_32"
DATA_ENCRYPTION_KEY="CHANGE_ME_openssl_rand_base64_32"

# --- Database (password di-set via docker compose POSTGRES_PASSWORD) ---
# DATABASE_URL dan DIRECT_URL di-override oleh docker-compose.production.yml

# --- Redis (Upstash — wajib production) ---
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- Cron (opsional, untuk /api/cron/*) ---
CRON_SECRET="CHANGE_ME_openssl_rand_base64_32"

# --- Cloudflare R2 ---
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="indoteknizi"
R2_ENDPOINT="https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com"
R2_PUBLIC_BASE_URL="https://pub-xxxxxxxx.r2.dev"

# --- Backup database (bucket private terpisah — lihat docs/deploy/DATABASE-BACKUP.md) ---
# BACKUP_R2_BUCKET="bantoo-backups"
# BACKUP_R2_ENDPOINT="https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com"
# BACKUP_R2_READ_ACCESS_KEY_ID=""
# BACKUP_R2_READ_SECRET_ACCESS_KEY=""
# BACKUP_QUEUE_DIR="/app/backups-queue"

# --- Telegram (opsional) ---
TELEGRAM_BOT_TOKEN=""
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=""
TELEGRAM_WEBHOOK_SECRET=""

# --- Google OAuth (opsional — link di Profil) ---
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""

# --- Session ---
SESSION_IDLE_SECONDS=7200

# --- Payment webhook (jika dipakai) ---
# PAYMENT_WEBHOOK_SECRET=""

# --- Tripay Closed Payment ---
# Uji staging: pakai credential Sandbox (DEV-...) + TRIPAY_MODE=sandbox
# Go-live: ganti ke merchant production Bantoo.in + TRIPAY_MODE=production
# TRIPAY_API_KEY=""
# TRIPAY_PRIVATE_KEY=""
# TRIPAY_MERCHANT_CODE=""
# TRIPAY_MODE=sandbox
# TRIPAY_CALLBACK_URL="https://bantoo.in/api/payments/tripay/callback"

# JANGAN set di production:
# STRESS_TEST_MODE=true
